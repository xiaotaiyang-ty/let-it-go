# 环境变量配置说明
# 复制此文件为 .env.local 并填入实际值

# MongoDB Atlas 连接字符串
# 格式: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>
MONGODB_URI=

# JWT 密钥（随机字符串，用于用户认证）
# 可以用这个命令生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# AI API 配置（默认使用火山方舟）
AI_API_KEY=
AI_API_ENDPOINT=
AI_MODEL=

# 每日免费额度
FREE_DAILY_LIMIT=10
